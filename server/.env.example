# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection String
# Option 1: Local MongoDB
MONGODB_URI=mongodb://localhost:27017/ai_career_coach
# Option 2: MongoDB Atlas
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/ai_career_coach

# JWT Secret (use a long random string in production)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Google Gemini AI API Key
# Get your key at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Frontend URL (for CORS). Add your deployed frontend URL here if needed.
CLIENT_URL=http://localhost:5173
# CLIENT_URL=https://ai-career-coach-bice.vercel.app
